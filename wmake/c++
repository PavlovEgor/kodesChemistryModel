#------------------------------------------------------------------------------
# Additional rules for handling c++ files

ifeq (,$(strip $(NVARCH)))
    NVARCH := 120
endif

c++FLAGS += -std=c++17 -O3

ifneq (,$(findstring true,$(have_cuda)))
    c++FLAGS += -Dhave_cuda
    CC += -gpu=cc$(NVARCH) -cuda
    LINKEXE += -lcudart
    LINKLIBSO += -lcudart -shared -Xlinker --add-needed
    include $(WMAKE_LOCAL)/cuda

endif
#------------------------------------------------------------------------------
